{
  "version": 3,
  "pages404": true,
  "caseSensitive": false,
  "basePath": "",
  "redirects": [
    {
      "source": "/:path+/",
      "destination": "/:path+",
      "internal": true,
      "statusCode": 308,
      "regex": "^(?:/((?:[^/]+?)(?:/(?:[^/]+?))*))/$"
    }
  ],
  "headers": [],
  "rewrites": {
    "beforeFiles": [],
    "afterFiles": [],
    "fallback": []
  },
  "dynamicRoutes": [
    {
      "page": "/api/auth/[...nextauth]",
      "regex": "^/api/auth/(.+?)(?:/)?$",
      "routeKeys": {
        "nxtPnextauth": "nxtPnextauth"
      },
      "namedRegex": "^/api/auth/(?<nxtPnextauth>.+?)(?:/)?$"
    },
    {
      "page": "/api/drafts/[id]",
      "regex": "^/api/drafts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/drafts/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/api/drafts/[id]/html-override",
      "regex": "^/api/drafts/([^/]+?)/html\\-override(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/drafts/(?<nxtPid>[^/]+?)/html\\-override(?:/)?$"
    },
    {
      "page": "/api/drafts/[id]/regenerate",
      "regex": "^/api/drafts/([^/]+?)/regenerate(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/drafts/(?<nxtPid>[^/]+?)/regenerate(?:/)?$"
    },
    {
      "page": "/api/exports/[id]",
      "regex": "^/api/exports/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/api/exports/(?<nxtPid>[^/]+?)(?:/)?$"
    },
    {
      "page": "/drafts/[id]",
      "regex": "^/drafts/([^/]+?)(?:/)?$",
      "routeKeys": {
        "nxtPid": "nxtPid"
      },
      "namedRegex": "^/drafts/(?<nxtPid>[^/]+?)(?:/)?$"
    }
  ],
  "staticRoutes": [
    {
      "page": "/",
      "regex": "^/(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/(?:/)?$"
    },
    {
      "page": "/_not-found",
      "regex": "^/_not\\-found(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/_not\\-found(?:/)?$"
    },
    {
      "page": "/articles",
      "regex": "^/articles(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/articles(?:/)?$"
    },
    {
      "page": "/drafts",
      "regex": "^/drafts(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/drafts(?:/)?$"
    },
    {
      "page": "/login",
      "regex": "^/login(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/login(?:/)?$"
    },
    {
      "page": "/newsletters",
      "regex": "^/newsletters(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/newsletters(?:/)?$"
    },
    {
      "page": "/settings/ai",
      "regex": "^/settings/ai(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/settings/ai(?:/)?$"
    },
    {
      "page": "/sources",
      "regex": "^/sources(?:/)?$",
      "routeKeys": {},
      "namedRegex": "^/sources(?:/)?$"
    }
  ],
  "dataRoutes": [],
  "rsc": {
    "header": "rsc",
    "varyHeader": "rsc, next-router-state-tree, next-router-prefetch, next-router-segment-prefetch",
    "prefetchHeader": "next-router-prefetch",
    "didPostponeHeader": "x-nextjs-postponed",
    "contentTypeHeader": "text/x-component",
    "suffix": ".rsc",
    "prefetchSuffix": ".prefetch.rsc",
    "prefetchSegmentHeader": "next-router-segment-prefetch",
    "prefetchSegmentSuffix": ".segment.rsc",
    "prefetchSegmentDirSuffix": ".segments"
  },
  "rewriteHeaders": {
    "pathHeader": "x-nextjs-rewritten-path",
    "queryHeader": "x-nextjs-rewritten-query"
  }
}